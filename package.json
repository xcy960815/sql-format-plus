{
  "name": "sql-format-plus",
  "version": "2.3.1",
  "description": "Formats whitespaces in a SQL query to make it more readable.",
  "main": "dist/sql-format-plus.umd.js",
  "module": "dist/sql-format-plus.es.js",
  "typings": "./types/sql-format-plus.d.ts",
  "files": [
    "dist",
    "types",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./types/sql-format-plus.d.ts",
      "import": "./dist/sql-format-plus.es.js",
      "default": "./dist/sql-format-plus.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "rollup -c",
    "check": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "link": "npm link && npm link sql-format-plus",
    "prepare": "husky",
    "preview": "vite preview",
    "serve": "vite"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "sql",
    "formatter",
    "format",
    "n1ql",
    "db2",
    "plsql"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcy960815/sql-formatter-plus.git"
  },
  "author": {
    "name": "xcy960815",
    "email": "18763006837@163.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/xcy960815/sql-formatter-plus/issues"
  },
  "homepage": "https://github.com/xcy960815/sql-formatter-plus#readme",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.8.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "rollup": "^4.44.1",
    "rollup-plugin-dts": "^6.2.1",
    "tslib": "^2.0.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^5.4.10",
    "vitepress": "^1.3.4"
  }
}
