{
  "compilerOptions": {
    "target": "es2015",
    "module": "es2015",
    "rootDir": "./src",
    "strict": true,
    "sourceMap": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2015", "dom"]
  },
  "include": ["src/**/*.ts"]
}
